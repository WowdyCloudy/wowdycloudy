{
  "datasets": [
    {
      "name": "8ce8abd2",
      "displayName": "GenieCodeDailyEvents",
      "queryLines": [
        "SELECT\n",
        "  event_date,\n",
        "  initiated_by,\n",
        "  COUNT(*) AS interact_count\n",
        "FROM\n",
        "  system.access.assistant_events\n",
        "WHERE\n",
        "  event_date >= '2026-07-06' -- Genie Pricing Model change\n",
        "GROUP BY\n",
        "  ALL\n",
        "ORDER BY\n",
        "  event_date DESC"
      ]
    },
    {
      "name": "cb77fad0",
      "displayName": "GenieDailyLLM",
      "queryLines": [
        "-- ToDo: Add filters below\n",
        "SELECT\n",
        "  workspace_id,\n",
        "  usage_date,\n",
        "  identity_metadata.run_as User,\n",
        "  SUM(usage_quantity * lp.pricing.effective_list.default) Genie_Cost,\n",
        "  currency_code Currency,\n",
        "  SUM(usage_quantity) LLM_DBUs\n",
        "FROM\n",
        "  system.billing.usage usage\n",
        "    JOIN system.billing.list_prices lp\n",
        "      ON usage.sku_name = lp.sku_name\n",
        "      AND usage.cloud = lp.cloud\n",
        "      AND price_start_time <= usage_start_time\n",
        "      AND (\n",
        "        price_end_time IS NULL\n",
        "        or price_end_time >= usage_start_time\n",
        "      )\n",
        "WHERE\n",
        "  usage_date >= '2026-07-06' -- Genie Pricing Model change\n",
        "  AND UPPER(billing_origin_product) = 'GENIE'\n",
        "GROUP BY\n",
        "  ALL\n",
        "ORDER BY\n",
        "  User,\n",
        "  usage_date DESC"
      ]
    }
  ],
